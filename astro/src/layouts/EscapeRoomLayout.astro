---
import type { Breadcrumbs, PageMetadata } from "../lib/types";

import "../styles/bootstrap.scss";
import { getEntry } from "astro:content";

import Metadata from "../components/Metadata.astro";
import Branding from "../components/Branding.astro";
import Column from "../components/Column.astro";
import FooterLinkList from "../components/navigation/FooterLinkList.astro";
import HeaderER from "../components/HeaderER.astro";
import { Icon } from "astro-icon/components";
import Row from "../components/Row.astro";

// Single these from the Header.
const navLinks = [{
  name: "Build-Your-Own Rooms",
  href: "/escape-room/themes",
}, {
  name: "How it Works",
  href: "/escape-room/how-it-works",
}, {
  name: "Our Story",
  href: "/escape-room/our-story",
}];

interface Props {
  title: string;
  crumbs?: Breadcrumbs;
  metadata?: PageMetadata;
}

const { metadata, crumbs, title } = Astro.props;
const socialEntry = await getEntry("navigation", "escape-social-media");
const socialLinks = socialEntry?.data.groups[0];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noarchive" />

    {
      metadata && (
        <Metadata {...metadata}>
          <slot name="metadata" slot="metadata" />
        </Metadata>
      )
    }
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <slot name="head" />
  </head>

  <body>
    <!-- Custom Header -->
    <HeaderER {title} {crumbs} />

    <main id="main-content">
      <div class="content-spacer"></div>
      <slot name="header" />
      <slot />
    </main>

    <!-- Custom Footer will be replaced with a component once mockups are available -->
    <footer class="escape-room-footer">
      <div class="container">
        <Row g="4">
          <Column noDefault lg="4">
            <h3 class="h5">About Us</h3>
            <p>
              We help organizations make their digital content accessible to
              people with disabilities.
            </p>
          </Column>
          <Column noDefault lg="4">
            <h3 class="h5">Quick Links</h3>
            <ul class="list-unstyled">
              {
                navLinks.map(({name, href}) => (
                  <li><a {href} class="link-offset-1" set:text={name} /></li>
                ))
              }
            </ul>
          </Column>
          <Column noDefault lg="4">
            <h3 class="h5">Contact Us</h3>
            <p>
              Have questions about our services?<br />
              <a href="mailto:info@accessiblecommunity.org"
                class="link-offset-1 link-truncate"
                >info@accessiblecommunity.org</a
              >
            </p>
          </Column>
        </Row>
        <Row>
          <h3 class="visually-hidden">Social Media</h3>
          <ul class="text-center mt-3 mt-md-4">
            {
              socialLinks?.map(({ icon, href, iconCls, name }) => (
                <li class="d-inline-block ms-2 me-3">
                  <a
                    class="d-inline-block link-light"
                    href={href}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <Icon
                      name={icon}
                      class:list={["social-icon", iconCls]}
                      role="img"
                      aria-label={name}
                    />
                  </a>
                </li>
              ))
            }
          </ul>
        </Row>
        <div class="text-center legal-footer">
          <p class="pt-2 text-center mb-0 text-light">
            <small>
              <Branding>Accessible Community</Branding> is a 501(c)3&nbsp;organization.
            </small>
          </p>
          <p class="mb-0">
            <small>&copy; {new Date().getFullYear()}
              <Branding>Accessible Community</Branding>
            </small>
          </p>
        </div>
        <p class="text-center mb-0 text-light">
      </div>
    </footer>
    <script src="../scripts/headings.js"></script>
    <script src="../scripts/body-no-scroll.js"></script>
    {
      import.meta.env.PROD && (
        <script
          is:inline
          defer
          data-domain="accessiblecommunity.org"
          src="https://plausible.io/js/script.js"
        />
      )
    }
  </body>
</html>

<style>
  /* Custom Footer Styles will be replaced with a component once mockups are available */
  .escape-room-footer {
    background: linear-gradient(135deg, #2c3e50 0%, var(--bs-black) 100%);
    color: white;
    padding: 1.5rem 0 2rem;
  }

  .escape-room-footer h3 {
    color: white;
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  .escape-room-footer a {
    color: white;
    --ac-link-focus-outline-color: white;
    --ac-link-hover-bg: white;
    transition: all 0.3s ease;
  }

  .escape-room-footer a:hover {
    color: var(--bs-black);
    opacity: 0.8;
  }

  .escape-room-footer hr {
    border-color: rgba(255, 255, 255, 0.1);
    margin: 2rem 0;
  }

  .social-icon {
    min-height: 24px;
    min-width: 24px;
  }

  .legal-footer {
    border-top: 1px solid #dfe1ed;
    margin: 0 1.5em;
  }

  /* Mobile Responsiveness */
  @media (max-width: 991.98px) {
    .escape-room-footer {
      padding: 3rem 0 1.5rem;
      margin-top: 3rem;
    }

    /* .escape-room-footer .footer-column {
      margin-bottom: 2rem;
    }

    .escape-room-footer .footer-column:last-child {
      margin-bottom: 0;
    } */
  }
</style>

