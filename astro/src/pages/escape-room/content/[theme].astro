---
import { auth } from "@lib/auth";
import { getEntry, render } from "astro:content";
import EscapeRoomContentLayout from "src/layouts/EscapeRoomContentLayout.astro";
import Section from "@components/Section.astro";

// import type { PurchaseSession } from "src/lib/session-store";

export const prerender = false
const { theme } = Astro.params;
if (!theme) {
  return Astro.redirect('/escape-room/access?error=content-missing');
}

const entry = await getEntry("escapeRoomKits", theme);

if (!entry) {
  return Astro.redirect('/escape-room/access?error=content-missing');
}

const {session, user} = Astro.locals;
if (!session || !user) {
  const data = await auth.api.signInMagicLink({
      body: {
          email: "user@email.com", // required
          name: "my-name",
          callbackURL: Astro.url.toString(),
          errorCallbackURL: "/error",
      },
      // This endpoint requires session cookies.
      headers: Astro.request.headers,
  });
  // throw new Response(null, { status: 401 });
  return Astro.redirect('/escape-room/access?error=content-missing');
}

// TODO: Verify that purchase happened in database.


const { Content } = await render(entry);
const title = entry.data.title;
---

<EscapeRoomContentLayout {title}>
  <Content components={{ Section }} />
</EscapeRoomContentLayout>
