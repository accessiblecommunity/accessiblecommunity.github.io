---
import Layout from "../../layouts/Layout.astro";
import ImageHeading from "../../components/ImageHeading.astro";
---

<Layout title="Team">
  <ImageHeading image="team" slot="header">Team</ImageHeading>
  <section class="container-fluid">
    <ul class="py-5 display-5">
      <li class="mb-3">
        <a href="/team/board" class="py-1 px-10">Board Members</a>
      </li>
      <li class="mb-3">
        <a href="/team/leadership" class="py-1 px-10">Leadership</a>
      </li>
      <li class="mb-3">
        <a href="/team/staff" class="py-1 px-10">Staff</a>
      </li>
      <li class="mb-3">
        <a href="/team/previous" class="py-1 px-10">Previous Contributors</a>
      </li>
      <li class="mb-3">
        <a href="/team/partners" class="py-1 px-10">Partners</a>
      </li>
    </ul>
  </section>
</Layout>
