---
// TODO: Commented out "partner" imports and variables
// import { getCollection } from "astro:content";
import { getOpenGraphImageData } from "@lib/og-image";
import type { Breadcrumbs, PageMetadata } from "@lib/types";

// const partners = await getCollection("collaborators", ({ data }) =>
//   data.tags.includes("evaluator"),
// );

const title = "Evaluations";
const metadata: PageMetadata = {
  title,
  description:
    "Overview of the Evaluations Service that Accessible Community provides",
  image: getOpenGraphImageData(Astro.site, "pages", "evaluations"),
};
const crumbs: Breadcrumbs = [
  {
    name: "Home",
    href: "/",
  },
];

import Branding from "@components/Branding.astro";
// import CollaboratorList from "@components/CollaboratorList.astro";
import Column from "@components/Column.astro";
import ExternalLink from "@components/ExternalLink.astro";
import FlexColumn from "@components/FlexColumn.astro";
import GoogleForm from "@components/forms/GoogleForm.astro";
import Hero from "@components/ColumnedHero.astro";
import { Icon } from "astro-icon/components";
import Layout from "src/layouts/Layout.astro";
import Row from "@components/Row.astro";
import ThemedBox from "@components/ThemedBox.astro";
import ThemedSection from "@components/ThemedSection.astro";

import heroBg from "src/images/colored-hero/woman-using-laptop.png";
import ShadowBoxSection from "@components/ShadowBoxSection.astro";
---

<Layout {title} {crumbs} {metadata}>
  <Hero image={heroBg} slot="header">
    <div class="py-2 px-2" slot="heading">
      <h1 class="display-3">
        Accessibility evaluations for <strong
          >the&nbsp;rest&nbsp;of&nbsp;us</strong
        >.
      </h1>
    </div>
    <div class="py-3">
      <p class="text-bg-hero">
        <Branding>Accessible Community</Branding> provides affordable accessibility
        evaluations for websites and social media.
      </p>
      <FlexColumn xlFlexRow gap="2">
        <a class="btn btn-info" href="#request">Request an evaluation</a>
      </FlexColumn>
    </div>
  </Hero>

  <ThemedSection style="tertiary">
    <h2 class="display-4 mb-3">
      Are you reaching <strong>everyone</strong> in your community?
    </h2>
    <FlexColumn
      gap="2" xlReverse class="justify-content-xl-evenly align-items-center"
    >
      <Column xl="8" xxl="9">
        <p>
          Websites and social media are often the first way people find your organization. We can help you reach more readers, more members, more customers by making your digital content accessible.
        </p>
        <p>
          <Branding class="text-primary">Accessible Community</Branding> evaluates websites and social media for small and medium size businesses and organizations. Evaluations are free for small businesses and community organizations, as well as disability-support organizations. We charge a small flat fee for our services to larger organizations and businesses.
        </p>
      </Column>
      <Column lg="10" xl="3" class="mx-3">
        <p
          class="display-5 text-center text-primary py-3 border-primary-subtle border-2 border-top border-bottom"
        >
          Evaluations are <strong>free</strong> for <strong>small businesses</strong> and <strong>community organizations</strong>.
        </p>
      </Column>
    </FlexColumn>
    <p>
      We provide a detailed report based on international standards and best practices to help you reach as many people as possible with your business or mission. We also help you get there with additional assistance after the evaluation.
    </p>
    <p>
      Reach out to discuss options.
    </p>
    <hr class="border border-primary-subtle opacity-100">
    <p class="small">
      <Branding class="text-primary">Accessible Community</Branding> is a nonprofit organization dedicated to growing accessible communities through socially responsible technology. We provide accessibility evaluations to smaller, community-based organizations to make digital accessibility affordable and achievable.
    </p>
  </ThemedSection>
  <ShadowBoxSection theme="info">
    <div class="text-center py-4">
      <h3 class="display-3 mx-auto">What are the <strong>options</strong>?</h3>
    </div>
    <Row baseRowCols="1" lgRowCols="2" gap="4" class="justify-content-center">
      <ThemedBox
        theme="primary"
        text={true}
        border={1}
        class="d-flex flex-column justify-content-between col-10 col-lg-5 shadow rounded"
      >
        <div>
          <h4 class="text-white">Standard Website Evaluation</h4>
          <p>
            What's included:
          </p>
          <ul class="bullets">
            <li
              >An accessibility review of up to 5 web pages, including the home
              page and global navigation</li
            >
            <li
              >A detailed report with links to additional learning about the
              issues and how to fix them</li
            >
            <li
              >Two hours of consulting to review findings and assist in fixing
              issues</li
            >
            <li>
              Access to three additional hours of support and training to prepare
              for next steps
              <ul class="small">
                <li>Additional hours of support are $100/hour</li>
              </ul>
            </li>
          </ul>
        </div>
        <p>
          Cost:
        </p>
        <ul class="bullets">
          <li><strong class="text-brand">Free</strong> for small businesses and community organizations</li>
          <li><strong class="text-brand">$1,500</strong> for larger community-centered organizations (such as local governments or community colleges)</li>
        </ul>
      </ThemedBox>
      <ThemedBox
        theme="primary"
        style="subtle"
        text={true}
        border={1}
        class="d-flex flex-column justify-content-between col-10 col-lg-5 shadow rounded"
      >
        <div>
          <h4 class="fw-bold">Social Media Evaluation</h4>
          <p>
            What's included:
          </p>
          <ul class="bullets">
            <li
              >A accessibility review of up to 3 social media platforms, including
              the organization pages, content and a sampling of 10-20 posts</li
            >
            <li
              >A detailed report with links to additional learning about the
              issues and how to fix them</li
            >
            <li
              >One hour of consulting to review findings and assist in fixing
              issues</li
            >
            <li>
              Access to one additional hour of support and training
              <ul class="small">
                <li>Additional hours of support are $100/hour</li>
              </ul>
            </li>
          </ul>
        </div>
        <p>
          Cost:
        </p>
        <ul class="bullets">
          <li><strong class="text-brand">Free</strong> for small businesses and community organizations</li>
          <li><strong class="text-brand">$750</strong> for larger community-centered organizations (such as local governments or community colleges)</li>
        </ul>
      </ThemedBox>
      <ThemedBox
        theme="secondary"
        text={true}
        border={1}
        class="d-flex d-none flex-column justify-content-between col-10 col-xl-8 shadow rounded"
      >
        <div>
          <h4 class="text-white">Self-Evaluation</h4>
          <p>
            We also provide <ExternalLink
              href="https://www.ta11y.org"
              class="link-light link-offset-1"
              inline
              gaps
              ><Icon
                name="ta11y-logo"
                role="img"
                aria-hidden="true"
                class="bi"
              /><Branding text="ta11y.org" /></ExternalLink
            >, a tool that will help you evaluate your digital content and learn
            more about accessibility. This evaluation tool will guide you
            step-by-step through an accessibility evaluation of your website,
            social media and other online content. It is designed specifically for
            those with little-to-no accessibility experience.
          </p>
          <p>
            <a href="/services/#ta11y" class="link-light link-offset-1">
              Read more about <Branding text="ta11y.org" /></a
            >
            to see if this free solution is for you.
          </p>
        </div>
        <p>Cost: <strong class="text-brand">$0</strong>.</p>
      </ThemedBox>
    </Row>
  </ShadowBoxSection>

  <ThemedSection id="request" theme="secondary" style="subtle" text={true}>
    <h2 class="display-4"><strong>Request</strong> an accessibility evaluation.</h2>
    <GoogleForm
      id="info-form"
      key="AKfycbxQZFm7FIKQabNEmwXbKdUh3IdMUY8efL4e8bEmkK_9rPvH6cUPrdNdQrIN6eMK-vI"
      >
      <div slot="prelude">
        <p>
          Please fill out this form to request an evaluation.
        </p>
        <h3 class="visually-hidden">Request form</h3>
      </div>
      <Row class="justify-content-lg-between">
        <Column noDefault lg="5">
          <div class="mb-3">
            <label for="nameField" class="form-label mb-1 required-field"
              >Your Name</label
            ><span class="asterisk"></span>
            <input
              type="text"
              name="Name"
              class="form-control w-100 form-field"
              id="nameField"
              autocomplete="name"
              required
            />
          </div>
          <div class="mb-3">
            <label for="orgNameField" class="form-label mb-1 required-field"
              >Organization Name</label
            ><span class="asterisk"></span>
            <input
              type="text"
              name="OrgName"
              class="form-control w-100 form-field"
              id="orgNameField"
              autocomplete="name"
              required
            />
          </div>
          <div class="mb-3">
            <label for="emailField" class="form-label mb-1 required-field"
              >Email Address</label
            ><span class="asterisk"></span>
            <input
              type="email"
              name="Email"
              class="form-control w-100 form-field"
              id="emailField"
              autocomplete="email"
              required
            />
          </div>
        </Column>
        <Column noDefault lg="6" class="mb-3">
          <div class="mb-3">
            <label for="phoneNumberField" class="form-label mb-1"
              >Phone Number</label
            >
            <input
              type="text"
              name="PhoneNumber"
              class="form-control w-100 form-field"
              id="phoneNumberField"
              autocomplete="tel"
            />
          </div>
          <label for="messageTextarea" class="form-label mb-1 required-field"
            >Message or Questions</label
          >
          <textarea
            name="Message"
            class="form-control w-100 form-text-area"
            id="messageTextarea"
            aria-describedby="messageHelp"
            rows="4"></textarea>
          <div id="messageHelp" class="form-text">
            Please add any additional information or questions you have.
          </div>
        </Column>
      </Row>
    </GoogleForm>
  </ThemedSection>
</Layout>

<style>
  p:has(+ .bullets) {
    margin-bottom: 0.333em;
  }
  .bullets {
    padding-inline-start: 1.5em;
    padding-block-end: 0.5em;
  }
  .small {
    font-size: 90%;
  }
  h4.text-white {
    font-weight: 600;
  }
</style>
