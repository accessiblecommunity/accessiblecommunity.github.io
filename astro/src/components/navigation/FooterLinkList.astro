---
import { getEntry } from 'astro:content';

interface Props {
  name: string;
}

const { name } = Astro.props;
const entry = await getEntry("navigation", name);

if (entry === undefined)
  throw new Error(`Could not find navigation entry '${name}'.`);

const { data } = entry;

import Branding from '@components/Branding.astro';
import ExternalLink from '@components/ExternalLink.astro';
import { Icon } from "astro-icon/components";
---

<h2 class="text-white fw-bold display-6" set:text={data.fullName} />
<ul class="list-unstyled list-spaced">
  { data.groups.map((linkGroup, index) => (
    <Fragment>
      { index !== 0 && <li><hr class="border-light" /></li> }
      { linkGroup.map(({ name, branded, href, external, icon, iconCls }) => (
        <li class="ms-2">
          { external
            ? <ExternalLink {href} inline class="link-light footer-link">{
                icon && (<Icon
                  class:list={["fli", iconCls]}
                  name={icon}
                  height={16}
                  role="img"
                  aria-hidden="true"
                />)
              }{ branded ? <Branding text={name} /> : name}</ExternalLink>
            : <a {href} class="link-light footer-link">{
                icon && (<Icon
                  class:list={["fli", iconCls]}
                  name={icon}
                  height={16}
                  role="img"
                  aria-hidden="true"
                />)
              }{ branded ? <Branding text={name} /> : name}</a>
          }
        </li>
      ))}
    </Fragment>
  ))}
  { Astro.slots.has('default') && <li><hr class="border-light" /></li> }
</ul>
<slot />

<style>
  .fli {
    height: 1em;
    width: auto;
    margin-right: 0.2em;
  }
</style>