---
import { undefined } from 'astro:schema';

type gapSizes = "1" | "2" | "3" | "4";
type gutterSizes = "1" | "2" | "3" | "4" | "5";

export interface Props {
  id?: string;
  class?: string;
  gap?: gapSizes;
  gutters?: gutterSizes;
  gx?: gutterSizes;
  gy?: gutterSizes;
}

const {
  id: elementID = "",
  class: cssClass = "",
  gap = undefined,
  gutters = undefined,
  gx = undefined,
  gy = undefined,
} = Astro.props;
---

<div class:list={[
  "row", 
  elementID,
  cssClass,
  gap && `gap-${gap}`,
  gutters && `g-${gutters}`,
  gx && `gx-${gutters}`,
  gy && `gy-${gutters}`,
]}><slot /></div>